# Example Ingress configuration for claudefana-enterprise.
# Copy this file to your overlay and customize for your environment.
#
# This example uses the AWS ALB Ingress Controller. For nginx or traefik,
# replace the annotations and ingressClassName accordingly.
#
# To use: copy to your Kustomize overlay and add to its kustomization.yaml resources.

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: claudefana-grafana
  namespace: claudefana
  annotations:
    # AWS ALB annotations — replace with your ingress controller's annotations
    alb.ingress.kubernetes.io/group.name: your-alb-group
    alb.ingress.kubernetes.io/healthcheck-path: /api/health
    alb.ingress.kubernetes.io/listen-ports: '[{"HTTPS":443}]'
    alb.ingress.kubernetes.io/scheme: internal
    alb.ingress.kubernetes.io/target-type: ip
spec:
  ingressClassName: alb
  rules:
    - host: grafana.example.com
      http:
        paths:
          - backend:
              service:
                name: grafana
                port:
                  number: 3000
            path: /
            pathType: Prefix
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: claudefana-otel
  namespace: claudefana
  annotations:
    alb.ingress.kubernetes.io/group.name: your-alb-group
    alb.ingress.kubernetes.io/healthcheck-path: /
    alb.ingress.kubernetes.io/listen-ports: '[{"HTTPS":443}]'
    alb.ingress.kubernetes.io/scheme: internal
    alb.ingress.kubernetes.io/target-type: ip
spec:
  ingressClassName: alb
  rules:
    - host: otel.example.com
      http:
        paths:
          - backend:
              service:
                name: otel-collector
                port:
                  number: 4318
            path: /
            pathType: Prefix
